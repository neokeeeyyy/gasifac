{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/gasifac/([^/.]+)$", "dest": "/public/gasifac/$1.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
