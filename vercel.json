{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/gasifac/(herramientas|nosotros|comprar|soporte)", "destination": "/gasifac/$1.html" },
    { "source": "/api/(.*)", "destination": "/api/index.py" }
  ]
}
